quarkus.application.name=request-flow-api
quarkus.http.port=${BACKEND_PORT:8080}
quarkus.http.root-path=/api

quarkus.datasource.db-kind=mysql
quarkus.datasource.username=${MYSQL_USER:requestflow_user}
quarkus.datasource.password=${MYSQL_PASSWORD:change_me}
quarkus.datasource.jdbc.url=jdbc:mysql://${MYSQL_HOST:localhost}:${MYSQL_PORT:3306}/${MYSQL_DATABASE:requestflow}

quarkus.hibernate-orm.database.generation=none
quarkus.hibernate-orm.log.sql=false

quarkus.http.cors.enabled=true
quarkus.http.cors.origins=${CORS_ORIGINS:http://localhost,http://localhost:80,http://localhost:4200,http://127.0.0.1,http://127.0.0.1:4200}
quarkus.http.cors.methods=GET,POST,PUT,PATCH,DELETE,OPTIONS
quarkus.http.cors.headers=accept,authorization,content-type,x-requested-with
quarkus.http.cors.access-control-allow-credentials=true

quarkus.http.auth.permission.options.paths=/*
quarkus.http.auth.permission.options.methods=OPTIONS
quarkus.http.auth.permission.options.policy=permit
quarkus.http.auth.permission.public.paths=/api/auth/login,/auth/login,/api/health/check,/health/check,/api/openapi,/openapi,/api/swagger-ui/*,/swagger-ui/*
quarkus.http.auth.permission.public.policy=permit
quarkus.http.auth.permission.authenticated-api.paths=/api/auth/me,/auth/me,/api/profile*,/profile*,/api/requests*,/requests*,/api/users*,/users*,/api/dashboard*,/dashboard*
quarkus.http.auth.permission.authenticated-api.policy=authenticated

quarkus.smallrye-openapi.path=/openapi
quarkus.swagger-ui.always-include=true
quarkus.swagger-ui.path=/swagger-ui

mp.jwt.verify.issuer=${JWT_ISSUER:request-flow-api}
mp.jwt.verify.publickey.algorithm=HS256
smallrye.jwt.verify.algorithm=HS256
smallrye.jwt.verify.secretkey=${JWT_SECRET:change_me_generate_a_secure_secret}
smallrye.jwt.sign.key=${JWT_SECRET:change_me_generate_a_secure_secret}
smallrye.jwt.new-token.signature-algorithm=HS256

requestflow.jwt.secret=${JWT_SECRET:change_me_generate_a_secure_secret}
requestflow.jwt.expiration.minutes=${JWT_EXPIRATION_MINUTES:120}

requestflow.seed.enabled=false
requestflow.ai.provider=${AI_PROVIDER:fallback}
requestflow.ai.api-key=${AI_API_KEY:}
requestflow.ai.model=${AI_MODEL:gemini-2.5-flash}
requestflow.ai.timeout.ms=${AI_TIMEOUT_MS:1200}

%dev.quarkus.hibernate-orm.database.generation=update
%dev.quarkus.hibernate-orm.log.sql=true
%dev.quarkus.datasource.username=${MYSQL_USER:requestflow_user}
%dev.quarkus.datasource.password=${MYSQL_PASSWORD:change_me}
%dev.quarkus.datasource.jdbc.url=jdbc:mysql://${MYSQL_HOST:localhost}:${MYSQL_PORT:3306}/${MYSQL_DATABASE:requestflow}
%dev.requestflow.seed.enabled=true
