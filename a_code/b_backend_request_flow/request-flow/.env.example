# RequestFlow backend environment example.
# Copy this file to .env only for local backend experiments.
# For Docker Compose, prefer the .env.example in the project root.
# If a password contains #, spaces, or special shell characters, wrap it in quotes.
# Example: MYSQL_PASSWORD="my#password"

MYSQL_DATABASE=requestflow
MYSQL_USER=requestflow_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me
MYSQL_HOST=localhost
MYSQL_PORT=3306

BACKEND_PORT=8080
FRONTEND_PORT=4200
QUARKUS_PROFILE=dev
FRONTEND_ORIGIN=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost,http://localhost:80

JWT_SECRET=change_me_generate_a_secure_secret
JWT_ISSUER=request-flow-api
JWT_EXPIRATION_MINUTES=120

# AI is optional. Use fallback for fastest local development.
# To use Gemini, set AI_PROVIDER=gemini and fill AI_API_KEY.
AI_PROVIDER=fallback
AI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_TIMEOUT_MS=1200
